# Copy to .env and fill in local values. Never commit the real .env file.

# --- Streaming ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions.raw

# --- Feature Store ---
ONLINE_FEATURE_STORE_URL=redis://localhost:6379/0
OFFLINE_FEATURE_STORE_PATH=./data/offline_store

# --- Model Registry ---
MODEL_REGISTRY_PATH=./models/registry
ACTIVE_MODEL_VERSION=gbt_v2.3.1

# --- Serving ---
SERVICE_PORT=8000
LATENCY_BUDGET_MS=100

# --- Monitoring ---
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
DRIFT_ALERT_PSI_THRESHOLD=0.2

# --- Cost Function (Decision Engine) ---
COST_FALSE_NEGATIVE_USD=250
COST_FALSE_POSITIVE_USD=15
